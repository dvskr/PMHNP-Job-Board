/// Per-employer testimonial / "share your story" submissions. Separate from
/// UserFeedback because:
///   - Has structured consent + display preferences (full / initial / anonymous)
///   - May or may not include a star rating (testimonial without rating is fine)
///   - Surfaced publicly when consent=true and featuredAt is set by an admin
///   - Tied back to the employer / posting for moderation and PR review
model EmployerTestimonial {
  id            String    @id @default(cuid())
  userId        String    @map("user_id")
  employerJobId String?   @map("employer_job_id")
