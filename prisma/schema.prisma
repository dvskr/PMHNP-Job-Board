generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Job {
  id                       String                    @id @default(uuid())
  title                    String
  slug                     String?                   @unique
  employer                 String
  location                 String
  jobType                  String?                   @map("job_type")
  mode                     String?
  experienceLevel          String?                   @map("experience_level")
  description              String
  descriptionSummary       String?                   @map("description_summary")
  salaryRange              String?                   @map("salary_range")
  minSalary                Int?                      @map("min_salary")
  maxSalary                Int?                      @map("max_salary")
  salaryPeriod             String?                   @map("salary_period")
  city                     String?
  state                    String?
  stateCode                String?                   @map("state_code")
  country                  String?                   @default("US")
  isRemote                 Boolean                   @default(false) @map("is_remote")
  isHybrid                 Boolean                   @default(false) @map("is_hybrid")
  normalizedMinSalary      Int?                      @map("normalized_min_salary")
  normalizedMaxSalary      Int?                      @map("normalized_max_salary")
  salaryIsEstimated        Boolean                   @default(false) @map("salary_is_estimated")
  salaryConfidence         Float?                    @map("salary_confidence")
  displaySalary            String?                   @map("display_salary")
  applyLink                String?                   @map("apply_link")
  applyOnPlatform          Boolean                   @default(false) @map("apply_on_platform")
  screeningQuestions       JobScreeningQuestion[]
  isFeatured               Boolean                   @default(false) @map("is_featured")
  isPublished              Boolean                   @default(true) @map("is_published")
  isManuallyUnpublished    Boolean                   @default(false) @map("is_manually_unpublished")
  // ── Unpublish reason capture ──
  // Set when an employer manually unpublishes ("Pause") via the dashboard
  // modal. Powers outreach + feedback signal. See migration
  // 20260502_add_unpublish_reason. Most-recent value wins if the employer
  // republishes and unpublishes again.
  unpublishReason          String?                   @map("unpublish_reason") @db.VarChar(60)
  unpublishReasonNote      String?                   @map("unpublish_reason_note") @db.Text
  unpublishedAt            DateTime?                 @map("unpublished_at")
  archivedAt               DateTime?                 @map("archived_at")
  isVerifiedEmployer       Boolean                   @default(false) @map("is_verified_employer")
  benefits                 String[]                  @default([])
  setting                  String?                   @map("clinical_setting")
  population               String?                   @map("patient_population")
  sourceType               String?                   @map("source_type")
  sourceProvider           String?                   @map("source_provider")
  sourceSite               String?                   @map("source_site")
  externalId               String?                   @map("external_id")
  viewCount                Int                       @default(0) @map("view_count")
  applyClickCount          Int                       @default(0) @map("apply_click_count")
  qualityScore             Int                       @default(0) @map("quality_score")
  createdAt                DateTime                  @default(now()) @map("created_at")
  updatedAt                DateTime                  @updatedAt @map("updated_at")
  expiresAt                DateTime?                 @map("expires_at")
  companyId                String?                   @map("company_id")
  originalPostedAt         DateTime?                 @map("original_posted_at")
  lastLinkCheckedAt        DateTime?                 @map("last_link_checked_at")
  lastEnrichedAt           DateTime?                 @map("last_enriched_at")
  // Source-presence tracking — incremented when a job's external_id is missing
  // from a successful source ingest. Resets to 0 on each re-appearance.
  // Currently shadow-mode: written but not used to auto-unpublish until tuned.
  healthConsecutiveMissing Int                       @default(0) @map("health_consecutive_missing")
  healthLastSeenAt         DateTime?                 @map("health_last_seen_at")
  // ─── Category tags (P9 — kills cross-taxonomy duplication) ───
  // Pre-computed canonical category slugs that this job qualifies for.
  // Populated at ingest by lib/pseo/category-tagger.ts and at query time
  // by buildWhere. Replaces the OR-on-`title.contains`/`description.contains`
  // matchers that produced ~5x duplication across taxonomy×city pages.
  // Empty array (default) means "not yet tagged" — buildWhere falls back
  // to the legacy matcher in that case so the rollout is safe to deploy
  // before backfill runs. After scripts/backfill-category-tags.ts has
  // populated all rows, the legacy fallback is dead code.
  categoryTags             String[]                  @default([]) @map("category_tags")
  applyClicks              ApplyClick[]
  jobApplications          JobApplication[]
  jobReports               JobReport[]
  jobViewEvents            JobViewEvent[]
  employerJobs             EmployerJob?
  employerMessages         EmployerMessage[]
  conversations            Conversation[]
  company                  Company?                  @relation(fields: [companyId], references: [id])
  healthChecks             JobHealthCheck[]
  embedding                JobEmbedding?
  recommendations          CandidateRecommendation[]

  @@index([isPublished])
  @@index([isFeatured])
  @@index([location])
  @@index([createdAt(sort: Desc)])
  @@index([minSalary, maxSalary])
  @@index([state])
  @@index([isRemote])
  @@index([companyId])
  @@index([slug])
  @@index([externalId, sourceProvider])
  @@index([qualityScore(sort: Desc)])
  @@index([sourceProvider, healthConsecutiveMissing])
  // GIN index for fast `categoryTags has 'X'` queries that drive every
  // taxonomy×city and taxonomy×state page after P9 swap.
  @@index([categoryTags], type: Gin)
  @@map("jobs")
}

/// Append-only audit log of every job-health decision.
/// Records the evidence behind each `is_published` flip so we can:
///   - Compute false-positive rates per checker / pattern / source.
///   - Answer support tickets ("why was my job removed?").
///   - Build multi-signal voting (Sprint 4) on top of the history.
///   - Run anomaly detection (Sprint 5) when dead-rate moves >Nσ.
///
/// Never delete rows. Retention is enforced by a partitioned monthly
/// vacuum job (Sprint 5) — until then the table grows ~100k rows/week.
model JobHealthCheck {
  id        String   @id @default(uuid())
  jobId     String   @map("job_id")
  checkedAt DateTime @default(now()) @map("checked_at")

  /// What kind of check produced this row.
  /// 'http_probe' | 'greenhouse_api' | 'source_presence'
  checkType String @map("check_type")

  /// Specific outcome — mirrors HealthReason / PresenceCheckOutcome literals.
  outcome String

  /// Convenience boolean — true means "alive or inconclusive".
  alive Boolean

  // ── HTTP-probe / greenhouse-api evidence (nullable when N/A) ──
  httpStatus    Int?    @map("http_status")
  redirectHops  Int?    @map("redirect_hops")
  finalUrl      String? @map("final_url")
  apiUrl        String? @map("api_url")
  softPatternId String? @map("soft_pattern_id")
  softMatchText String? @map("soft_match_text")
  errorKind     String? @map("error_kind")
  errorMessage  String? @map("error_message")
  elapsedMs     Int?    @map("elapsed_ms")

  // ── Source-presence evidence (nullable when N/A) ──
  presenceSource        String? @map("presence_source")
  presenceFetched       Int?    @map("presence_fetched")
  presenceHistoricalAvg Float?  @map("presence_historical_avg")
  presenceSeenAgain     Int?    @map("presence_seen_again")
  presenceMissing       Int?    @map("presence_missing")
  presenceSkippedReason String? @map("presence_skipped_reason")

  /// Stable identifier for the rule set that produced this row. Bump
  /// when patterns / decision logic changes so old rows stay comparable.
  checkerVersion String @map("checker_version")

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, checkedAt(sort: Desc)])
  @@index([outcome, checkedAt(sort: Desc)])
  @@index([checkedAt(sort: Desc)])
  @@map("job_health_checks")
}

model EmailLead {
  id                String     @id @default(cuid())
  email             String     @unique
  preferences       Json       @default("{}")
  source            String?
  isSubscribed      Boolean    @default(true) @map("is_subscribed")
  isSuppressed      Boolean    @default(false) @map("is_suppressed")
  suppressedAt      DateTime?  @map("suppressed_at")
  suppressionReason String?    @map("suppression_reason")
  newsletterOptIn   Boolean    @default(false) @map("newsletter_opt_in")
  unsubscribeToken  String     @unique @default(cuid()) @map("unsubscribe_token")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")
  jobAlerts         JobAlert[]

  @@index([email])
  @@index([unsubscribeToken])
  @@map("email_leads")
}

model JobAlert {
  id                String    @id @default(cuid())
  email             String
  name              String?
  keyword           String?
  location          String?
  mode              String?
  jobType           String?   @map("job_type")
  minSalary         Int?      @map("min_salary")
  maxSalary         Int?      @map("max_salary")
  frequency         String    @default("weekly")
  // Double opt-in (CASL / GDPR best practice). New rows start with
  // is_active = false and confirmed_at = null. The send-alerts cron
  // only fires for confirmed alerts. Flipped by /api/job-alerts/confirm.
  isActive          Boolean   @default(false) @map("is_active")
  confirmedAt       DateTime? @map("confirmed_at")
  confirmationToken String?   @unique @default(cuid()) @map("confirmation_token")
  lastSentAt        DateTime? @map("last_sent_at")
  token             String    @unique @default(cuid())
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  emailLead         EmailLead @relation(fields: [email], references: [email])

  @@index([email])
  @@index([token])
  @@index([isActive])
  @@index([confirmedAt])
  @@map("job_alerts")
}

model EmployerJob {
  id                  String           @id @default(uuid())
  employerName        String           @map("employer_name")
  contactEmail        String           @map("contact_email")
  companyLogoUrl      String?          @map("company_logo_url")
  companyDescription  String?          @map("company_description")
  companyWebsite      String?          @map("company_website")
  jobId               String           @unique @map("job_id")
  editToken           String           @unique @map("edit_token")
  dashboardToken      String           @unique @default(cuid()) @map("dashboard_token")
  paymentStatus       String           @map("payment_status")
  pricingTier         String           @default("pro") @map("pricing_tier")
  // Immutable snapshot of the signup email's domain at posting time.
  // Used as the canonical anchor for the free-post quota count so that:
  //   - Editing contactEmail can't shift the count
  //   - Deleting/nullifying userId (account deletion) can't drop the count
  //   - Form-submitted contactEmail can be anything (recruiter posting on
  //     behalf of a client, multi-brand orgs, etc.) without affecting quota
  // Set ONLY at row creation by /api/jobs/post-free; never written by any
  // update path. Null on legacy paid rows / pre-2026-05-01 rows that the
  // backfill couldn't infer; those rows don't drive the quota anyway.
  quotaDomain         String?          @map("quota_domain")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")
  expiryWarningSentAt DateTime?        @map("expiry_warning_sent_at")
  notifyOnApplication Boolean          @default(true) @map("notify_on_application")
  notifyDigest        String           @default("instant") @map("notify_digest") // instant, daily, off
  userId              String?          @map("user_id")
  job                 Job              @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user                UserProfile?     @relation(fields: [userId], references: [supabaseId])
  profileViews        ProfileView[]
  savedCandidates     SavedCandidate[]

  @@index([userId])
  @@index([editToken])
  @@index([contactEmail])
  @@index([dashboardToken])
  @@index([quotaDomain, paymentStatus])
  @@map("employer_jobs")
}

/// Idempotency log for Stripe webhook events. Audit #3: Stripe redelivers
/// `checkout.session.completed` on transient failures or manual replays. Without
/// this dedupe, the handler sends duplicate confirmation emails and re-runs
/// state writes. We insert-then-process; on a unique-violation we skip safely.
model ProcessedStripeEvent {
  id          String   @id @default(uuid())
  eventId     String   @unique @map("event_id")
  eventType   String   @map("event_type")
  processedAt DateTime @default(now()) @map("processed_at")

  @@index([eventType])
  @@map("processed_stripe_events")
}

/// Per-charge ledger for paid job postings. Audit #2: replaces the broken
/// invoice-by-employerJob lookup that always printed $199 even for $179
/// renewals. One row per Stripe checkout (new post or renewal). Invoices
/// are now generated from this ledger so they always match the charged amount.
///
/// Refund fields (audit #28): populated by the `charge.refunded` webhook
/// handler when a refund is issued from Stripe Dashboard. `refundedAmountCents`
/// supports partial refunds; full-refund flag is `refundedAmountCents = amountCents`.
model JobCharge {
  id                    String    @id @default(uuid())
  employerJobId         String    @map("employer_job_id")
  stripeSessionId       String    @unique @map("stripe_session_id")
  stripePaymentIntentId String?   @unique @map("stripe_payment_intent_id")
  stripeInvoiceId       String?   @map("stripe_invoice_id")
  invoicePdfUrl         String?   @map("invoice_pdf_url")
  hostedInvoiceUrl      String?   @map("hosted_invoice_url")
  invoiceNumber         String?   @map("invoice_number")
  amountCents           Int       @map("amount_cents")
  currency              String    @default("usd")
  type                  String // 'new' | 'renewal'
  createdAt             DateTime  @default(now()) @map("created_at")
  refundedAt            DateTime? @map("refunded_at")
  refundedAmountCents   Int?      @map("refunded_amount_cents")
  refundReason          String?   @map("refund_reason")

  @@index([employerJobId])
  @@index([type])
  @@index([refundedAt])
  @@index([stripeInvoiceId])
  @@map("job_charges")
}

model SiteStat {
  id               String   @id @default(uuid())
  totalJobs        Int      @default(0) @map("total_jobs")
  totalSubscribers Int      @default(0) @map("total_subscribers")
  totalCompanies   Int      @default(0) @map("total_companies")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("site_stats")
}

model JobDraft {
  id          String   @id @default(cuid())
  email       String
  formData    Json     @map("form_data")
  resumeToken String   @unique @default(cuid()) @map("resume_token")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  expiresAt   DateTime @map("expires_at")

  @@index([email])
  @@index([resumeToken])
  @@map("job_drafts")
}

model Company {
  id             String   @id @default(uuid())
  name           String   @unique
  normalizedName String   @unique @map("normalized_name")
  aliases        String[] @default([])
  logoUrl        String?  @map("logo_url")
  website        String?
  description    String?
  jobCount       Int      @default(0) @map("job_count")
  isVerified     Boolean  @default(false) @map("is_verified")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  jobs           Job[]

  @@index([normalizedName])
  @@index([isVerified])
  @@map("companies")
}

model SourceStats {
  id               String   @id @default(uuid())
  source           String
  date             DateTime @db.Date
  jobsFetched      Int      @default(0) @map("jobs_fetched")
  jobsAdded        Int      @default(0) @map("jobs_added")
  jobsDuplicate    Int      @default(0) @map("jobs_duplicate")
  jobsExpired      Int      @default(0) @map("jobs_expired")
  // Sum of all rejection-reason counts in `rejectedByReason`. Captures
  // the funnel collapse (e.g. greenhouse fetched=47k → added=37 →
  // jobsRejected=39k+), so trend queries don't need to scan rejected_jobs.
  jobsRejected     Int      @default(0) @map("jobs_rejected")
  // Per-reason breakdown: { relevance_no_keyword: 12k, normalizer_low_completeness: 4k, ... }.
  // Populated 2026-05-06+. NULL for rows from older runs.
  rejectedByReason Json?    @map("rejected_by_reason")
  avgQualityScore  Float?   @map("avg_quality_score")
  totalViews       Int      @default(0) @map("total_views")
  totalApplyClicks Int      @default(0) @map("total_apply_clicks")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@unique([source, date])
  @@index([source])
  @@index([date])
  @@map("source_stats")
}

model ApplyClick {
  id        String   @id @default(uuid())
  jobId     String   @map("job_id")
  source    String?
  timestamp DateTime @default(now())
  sessionId String?  @map("session_id")
  referrer  String?
  userAgent String?  @map("user_agent")
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([source])
  @@index([timestamp])
  @@map("apply_clicks")
}

model EmployerLead {
  id              String    @id @default(uuid())
  companyName     String    @map("company_name")
  contactName     String?   @map("contact_name")
  contactEmail    String?   @map("contact_email")
  contactTitle    String?   @map("contact_title")
  // Added 2026-05-06 for description-mined leads (regex'd phone numbers
  // out of job postings). Format kept as raw extracted string for now —
  // a follow-up can normalize to E.164 if we ever auto-dial.
  phone           String?
  website         String?
  linkedInUrl     String?   @map("linkedin_url")
  notes           String?
  status          String    @default("prospect")
  source          String?
  lastContactedAt DateTime? @map("last_contacted_at")
  nextFollowUpAt  DateTime? @map("next_follow_up_at")
  jobsPosted      Int       @default(0) @map("jobs_posted")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([status])
  @@index([companyName])
  @@index([contactEmail])
  @@map("employer_leads")
}

model UserProfile {
  id              String  @id @default(cuid())
  supabaseId      String  @unique @map("supabase_id")
  email           String  @unique
  role            String  @default("job_seeker")
  firstName       String? @map("first_name")
  lastName        String? @map("last_name")
  phone           String?
  company         String?
  resumeUrl       String? @map("resume_url")
  avatarUrl       String? @map("avatar_url")
  emailSuppressed Boolean @default(false) @map("email_suppressed")

  // PMHNP-specific professional fields
  headline        String?  @map("headline")
  yearsExperience Int?     @map("years_experience")
  certifications  String?  @map("certifications")
  licenseStates   String?  @map("license_states")
  specialties     String?  @map("specialties")
  bio             String?  @map("bio")
  linkedinUrl     String?  @map("linkedin_url")
  skills          String[] @default([])

  // AI Resume Parsing
  resumeParsedAt    DateTime? @map("resume_parsed_at")
  resumeParseStatus String?   @map("resume_parse_status") // pending, completed, failed

  // Job preferences
  preferredWorkMode String?   @map("preferred_work_mode")
  preferredJobType  String?   @map("preferred_job_type")
  desiredSalaryMin  Int?      @map("desired_salary_min")
  desiredSalaryMax  Int?      @map("desired_salary_max")
  desiredSalaryType String?   @map("desired_salary_type")
  availableDate     DateTime? @map("available_date")

  // Visibility
  openToOffers   Boolean @default(true) @map("open_to_offers")
  profileVisible Boolean @default(true) @map("profile_visible")

  // ── Address ──
  addressLine1 String? @map("address_line_1")
  addressLine2 String? @map("address_line_2")
  city         String?
  state        String?
  zipCode      String? @map("zip_code")
  country      String? @default("US")

  // ── EEO & Work Authorization (voluntary/sensitive) ──
  workAuthorized         Boolean?  @map("work_authorized")
  requiresSponsorship    Boolean?  @map("requires_sponsorship")
  veteranStatus          String?   @map("veteran_status")
  disabilityStatus       String?   @map("disability_status")
  raceEthnicity          String?   @map("race_ethnicity")
  gender                 String?
  // Separate consent for the use of sensitive personal info under
  // GDPR Art. 9 / CPRA SPI rules. Set to true only when the user
  // explicitly checks the consent box that appears in the profile
  // form when any EEO / DEA / NPI field is touched. Read by the
  // employer-facing serializer to redact those fields when false.
  sensitiveDataConsent   Boolean   @default(false) @map("sensitive_data_consent")
  sensitiveDataConsentAt DateTime? @map("sensitive_data_consent_at")

  // ── Federal Registrations ──
  npiNumber         String?   @map("npi_number")
  deaNumber         String?   @map("dea_number")
  deaExpirationDate DateTime? @map("dea_expiration_date")

  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")
  lastNudgedAt           DateTime? @map("last_nudged_at")
  lastSavedJobReminderAt DateTime? @map("last_saved_job_reminder_at")
  emailSuppressedAt      DateTime? @map("email_suppressed_at")

  // ── Activity tracking + soft-delete lifecycle (GDPR storage limitation) ──
  // lastSeenAt is bumped by middleware on each authenticated request (throttled
  // to once per 15 minutes). It feeds the inactive-user purge cron.
  // deletedAt is set on user-initiated account deletion; purgeAt is the
  // deadline after which the hard-purge cron physically removes the record.
  // purgeWarningEmailSentAt prevents the inactive purge from sending the
  // warning more than once.
  lastSeenAt              DateTime? @map("last_seen_at")
  deletedAt               DateTime? @map("deleted_at")
  purgeAt                 DateTime? @map("purge_at")
  purgeWarningEmailSentAt DateTime? @map("purge_warning_email_sent_at")

  // ── Relations ──
  employerJobs         EmployerJob[]
  jobApplications      JobApplication[]
  licenses             CandidateLicense[]
  certificationRecords CandidateCertification[]
  education            CandidateEducation[]
  workExperience       CandidateWorkExperience[]
  screeningAnswers     CandidateScreeningAnswer[]
  openEndedResponses   CandidateOpenEndedResponse[]

  candidateReferences CandidateReference[]
  autofillUsage       AutofillUsage[]
  autofillTelemetry   AutofillTelemetry[]
  sentMessages        EmployerMessage[]        @relation("SenderMessages")
  receivedMessages    EmployerMessage[]        @relation("RecipientMessages")
  conversationsA      Conversation[]           @relation("ConversationParticipantA")
  conversationsB      Conversation[]           @relation("ConversationParticipantB")
  savedByEmployers    SavedCandidate[]         @relation("SavedAsCandidate")
  savedCandidates     SavedCandidate[]         @relation("SavedByEmployer")
  candidateAlerts     EmployerCandidateAlert[]

  @@index([supabaseId])
  @@index([email])
  @@index([profileVisible, openToOffers, role])
  @@index([deletedAt])
  @@index([purgeAt])
  @@index([lastSeenAt])
  @@map("user_profiles")
}

model JobApplication {
  id              String    @id @default(cuid())
  userId          String    @map("user_id")
  jobId           String    @map("job_id")
  sourceUrl       String?   @map("source_url")
  coverLetter     String?   @map("cover_letter")
  coverLetterUrl  String?   @map("cover_letter_url")
  resumeUrl       String?   @map("resume_url")
  appliedAt       DateTime  @default(now()) @map("applied_at")
  status          String    @default("applied") // applied, screening, interview, offered, hired, rejected
  notes           String? // Private employer notes
  statusUpdatedAt DateTime? @map("status_updated_at")
  consentGiven    Boolean   @default(false) @map("consent_given")
  consentGivenAt  DateTime? @map("consent_given_at")
  withdrawnAt     DateTime? @map("withdrawn_at")

  // AI Candidate Scoring
  aiMatchScore   Int?     @map("ai_match_score") // 0-100
  aiMatchReasons String[] @default([]) @map("ai_match_reasons")
  aiMissingItems String[] @default([]) @map("ai_missing_items")

  // Screening Question Answers
  screeningAnswers Json? @map("screening_answers") // [{ questionId, questionText, answer }]

  user UserProfile @relation(fields: [userId], references: [supabaseId], onDelete: Cascade)
  job  Job         @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@index([userId])
  @@index([jobId])
  @@index([status])
  @@map("job_applications")
}

model JobViewEvent {
  id        String   @id @default(uuid())
  jobId     String   @map("job_id")
  timestamp DateTime @default(now())
  sessionId String?  @map("session_id")
  referrer  String?
  userAgent String?  @map("user_agent")
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([timestamp])
  @@index([jobId, timestamp])
  @@map("job_view_events")
}

model Conversation {
  id            String   @id @default(cuid())
  participantA  String   @map("participant_a")
  participantB  String   @map("participant_b")
  jobId         String?  @map("job_id")
  subject       String
