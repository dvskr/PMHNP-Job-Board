  // Did the employer explicitly consent to public display? Default false —
  // a testimonial without consent is internal-only.
  consent       Boolean   @default(false)
  // 'full' | 'initial' | 'anonymous' — controls how the name appears when
  // featured. Stored as text so we can extend without a migration.
  displayAs     String    @default("initial")
  // Set by an admin when this testimonial is approved for public display
