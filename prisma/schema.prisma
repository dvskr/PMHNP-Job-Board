// ─── GSC De-Indexing Queue (P2.1) ────────────────────────────────────
// Tracks URLs that should be proactively removed from Google's index via
// the Indexing API URL_DELETED endpoint. Seeded from GSC bulk exports
// (Not found / Crawled-not-indexed / Soft 404 categories) and from edge
// log scraping of 4xx responses to Googlebot.
//
// Drained by /api/cron/historical-deindex (every 6h):
//   1. HEAD-check the URL — if it's actually live, delete the row
//   2. Otherwise submit URL_DELETED to Google Indexing API + IndexNow
//   3. Mark submittedAt; row is kept for audit but not re-submitted
//
// Status values:
//   'pending'    — not yet processed
//   'submitted'  — successfully submitted to search engines
//   'live'       — HEAD-check returned 200; URL is alive, removed from queue
//   'failed'     — repeated submission failures (exhausted attempts)
model DeindexQueue {
  id          String    @id @default(cuid())
  url         String    @unique
  source      String // 'gsc-not-found' | 'gsc-crawled-not-indexed' | 'gsc-soft-404' | 'edge-log' | 'sitemap-diff' | 'manual'
  status      String    @default("pending") // 'pending' | 'submitted' | 'live' | 'failed'
  attempt     Int       @default(0)
  lastError   String?   @db.Text
  addedAt     DateTime  @default(now())
  submittedAt DateTime?
  updatedAt   DateTime  @updatedAt

  @@index([status, addedAt])
  @@index([source])
  @@map("deindex_queue")
}

// ─── Cron Run Log (P4.3) ─────────────────────────────────────────────
// Lightweight per-invocation log so we can: (a) detect crons that haven't
// run in their expected window (silent failures, schedule removed by
// mistake), (b) audit historical run frequency, (c) attach output metrics
// for trend analysis. Crons opt in via lib/cron/track.ts → recordCronRun.
//
// Indexed by (name, startedAt) so the watchdog query "most recent run for
// each cron name" is fast.
model CronRun {
  id         String    @id @default(cuid())
  name       String
  startedAt  DateTime  @default(now()) @map("started_at")
  finishedAt DateTime? @map("finished_at")
  success    Boolean   @default(false)
  durationMs Int?      @map("duration_ms")
  error      String?   @db.Text
  metrics    Json? // freeform metrics: { submitted: 50, dead: 32, alive: 18 } etc.

  @@index([name, startedAt(sort: Desc)])
  @@map("cron_runs")
}

// ─── GSC Health Snapshots (P4.2) ─────────────────────────────────────
// Daily snapshot of GSC Coverage report metrics. Lets us compare
// week-over-week and alert on regressions (rising not-indexed count,
// falling indexed count) via the gsc-health-check cron.
//
// Each row = one day's totals. Named columns mirror GSC's error category
// labels so queries are self-documenting. `raw` keeps the full Search
// Console API payload for ad-hoc forensic queries.
model GscSnapshot {
  id                   String   @id @default(cuid())
  capturedOn           DateTime @unique @map("captured_on") @db.Date
  indexedTotal         Int      @default(0) @map("indexed_total")
  notIndexedTotal      Int      @default(0) @map("not_indexed_total")
  notFound404          Int      @default(0) @map("not_found_404")
  serverError5xx       Int      @default(0) @map("server_error_5xx")
  softFour04           Int      @default(0) @map("soft_404")
  crawledNotIndexed    Int      @default(0) @map("crawled_not_indexed")
  discoveredNotIndexed Int      @default(0) @map("discovered_not_indexed")
  duplicateNoCanonical Int      @default(0) @map("duplicate_no_canonical")
  excludedNoindex      Int      @default(0) @map("excluded_noindex")
  pageWithRedirect     Int      @default(0) @map("page_with_redirect")
  blockedByRobots      Int      @default(0) @map("blocked_by_robots")
  indexedButBlocked    Int      @default(0) @map("indexed_but_blocked")
  raw                  Json?
  createdAt            DateTime @default(now()) @map("created_at")

  @@map("gsc_snapshots")
}

// ─── pSEO Narrative Snippets (P3.4) ──────────────────────────────────
// Optional LLM-generated overrides for the deterministic narratives in
// lib/pseo/city-narrative.ts. The renderer prefers DB rows; falls back
// to the deterministic narrative when no override exists. This lets us
// upgrade the top ~50 cities (highest job count / impressions) with
// editorial-grade prose without paying LLM cost on every page.
//
// Generation flow:
//   1. scripts/generate-city-snippets.ts picks targets (top N by job count)
//   2. Calls Claude API with city facts + taxonomy lead + style prompt
//   3. Stores result here
//   4. Page renders from this row if found
//
// Schema notes:
//   - body is plain text (no HTML) — renderer escapes + wraps in <p>
//   - sourceModel records which model generated it (for re-runs after upgrades)
//   - approvedAt nullable — un-approved drafts won't render until human review
model CitySnippet {
  id          String    @id @default(cuid())
  citySlug    String    @unique @map("city_slug")
  body        String    @db.Text
  sourceModel String?   @map("source_model") // e.g. "claude-opus-4-7", "manual"
  generatedAt DateTime  @default(now()) @map("generated_at")
  approvedAt  DateTime? @map("approved_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([approvedAt])
  @@map("city_snippets")
}

model CategoryCitySnippet {
  id           String    @id @default(cuid())
  categorySlug String    @map("category_slug")
  citySlug     String    @map("city_slug")
  body         String    @db.Text
  sourceModel  String?   @map("source_model")
  generatedAt  DateTime  @default(now()) @map("generated_at")
  approvedAt   DateTime? @map("approved_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@unique([categorySlug, citySlug])
  @@index([approvedAt])
  @@map("category_city_snippets")
}

// ─── Programmatic SEO Stats ──────────────────────────────────────────
model PseoStats {
  id                String   @id @default(cuid())
  type              String
  categorySlug      String
  locationSlug      String
  totalJobs         Int      @default(0)
  rawAvgSalary      Int      @default(0)
  colAdjustedSalary Int      @default(0)
  updatedAt         DateTime @updatedAt

  @@unique([type, categorySlug, locationSlug])
  @@index([type, locationSlug])
  @@index([categorySlug])
}

// ─── Data Subject Access Requests (DSAR) ─────────────────────────────
// Tracks GDPR Art. 15-22 / CCPA-CPRA requests. SLA: 30 days (GDPR)
// or 45 days (CCPA, with 45-day extension on notice).
//
// IMPORTANT: this model was added in commit "feat(privacy): DSAR intake".
// Run `npx prisma migrate dev --name add_data_request` to apply.
model DataRequest {
  id           String  @id @default(cuid())
  email        String
  fullName     String? @map("full_name")
  type         String // 'access' | 'deletion' | 'correction' | 'portability' | 'object' | 'restrict' | 'opt_out_sale'
  description  String? @db.Text
  jurisdiction String? // 'gdpr' | 'ccpa' | 'lgpd' | 'pipeda' | 'other'

  // Tracking
  status           String  @default("received") // 'received' | 'in_progress' | 'awaiting_id' | 'completed' | 'rejected'
  identityVerified Boolean @default(false) @map("identity_verified")
  resolutionNote   String? @map("resolution_note") @db.Text

  // Audit timestamps
  createdAt      DateTime  @default(now()) @map("created_at")
  acknowledgedAt DateTime? @map("acknowledged_at")
  completedAt    DateTime? @map("completed_at")
  dueBy          DateTime  @map("due_by") // computed at insert time from jurisdiction

  // Anti-abuse — IP for rate limiting; cleared after completion
  requesterIp String? @map("requester_ip")
  userAgent   String? @map("user_agent") @db.Text

  @@index([email])
  @@index([status])
  @@index([dueBy(sort: Asc)])
  @@index([createdAt(sort: Desc)])
  @@map("data_requests")
}

// ─── Audit Log ──────────────────────────────────────────────────────
// Append-only record of sensitive actions (deletions, exports, role
// changes, DSAR completions, cron purges, etc.). Used for SOC2 audit
// trail and GDPR Art. 30 record-of-processing.
//
// Forward-only — rows here should never be updated or deleted.
// A periodic archival job (>365 days) can move old rows to cold storage
// but deletion is never automatic.
model AuditLog {
  id         String   @id @default(cuid())
  action     String // 'account.delete' | 'account.restore' | 'account.purge' | 'data.export' | 'data.request.received' | 'data.request.completed' | 'role.change' | 'cron.purge_soft_deleted' | 'cron.purge_inactive' | etc.
  actorType  String   @map("actor_type") // 'user' | 'admin' | 'system'
  actorId    String?  @map("actor_id") // null when actorType = 'system'
  targetType String?  @map("target_type") // 'user' | 'job' | 'application' | 'data_request'
  targetId   String?  @map("target_id")
  ip         String?
  userAgent  String?  @map("user_agent") @db.Text
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([action])
  @@index([actorId])
  @@index([targetType, targetId])
  @@index([createdAt(sort: Desc)])
  @@map("audit_logs")
}

// Phase 1 Sprint 1.2 — daily personalized job recommendations. The
// recommendations.daily Inngest cron generates one batch per active candidate
// and writes ranked rows here. The "For you" UI on /candidate/dashboard reads
// the latest batch via batchId. Click-through is captured via /api/recommendations/click.
model CandidateRecommendation {
  id          String    @id @default(cuid())
  supabaseId  String    @map("supabase_id")
  jobId       String    @map("job_id")
  batchId     String    @map("batch_id")
  rank        Int
  similarity  Float
  /// Conversion-tier classification — 'easy_apply' | 'direct_apply' | 'external'.
  /// Source of truth lives in lib/ai/job-classifier.ts; recs cron persists it
  /// so the dashboard can render tier badges without a join back to Job.
  tier        String    @default("external")
  reason      String?
  clickedAt   DateTime? @map("clicked_at")
  dismissedAt DateTime? @map("dismissed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([supabaseId, batchId, rank])
  @@index([supabaseId, jobId, createdAt(sort: Desc)])
  @@index([clickedAt(sort: Desc)])
  @@index([tier])
  @@map("candidate_recommendations")
}

// Phase 0 Sprint 0.4 — per-tenant feature flag overrides. The decision order
// in lib/ai/feature-flags.ts is: env kill (KILL_AI_<FLAG>=1) > DB override
// (this table) > compiled default. An admin can disable any AI feature for
// any (or every) tenant in <1 minute by inserting a row here.
model AiFeatureFlagOverride {
  id         String    @id @default(cuid())
  flag       String // e.g. 'ai.candidate.cover_letter'
  tenantType String    @map("tenant_type") // 'employer' | 'candidate' | 'admin' | 'global'
  tenantId   String?   @map("tenant_id") // null when tenantType = 'global'
  enabled    Boolean
  reason     String?
  setBy      String?   @map("set_by")
  expiresAt  DateTime? @map("expires_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@index([flag])
  @@index([expiresAt])
  @@map("ai_feature_flag_override")
}

// Phase 0 Sprint 0.3 — per-job embedding for semantic search and
// recommendations. Refreshed by the embedding worker (lib/inngest/functions/
// embeddings.ts) on job.created / job.updated events. The vector column is
// modeled as Unsupported because Prisma 7 has no first-class pgvector type;
// reads/writes go through $queryRaw helpers in lib/ai/vector-search.ts.
model JobEmbedding {
  jobId     String                      @id @map("job_id")
  embedding Unsupported("vector(1536)")
  model     String                      @default("text-embedding-3-small")
  inputHash String                      @map("input_hash")
  updatedAt DateTime                    @default(now()) @map("updated_at")

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([updatedAt(sort: Desc)])
  @@map("job_embeddings")
}

// Phase 0 Sprint 0.3 — per-candidate embedding. No FK because embedding refresh
// races with profile delete; orphan rows are cleaned by the lifecycle cron.
model CandidateEmbedding {
  supabaseId String                      @id @map("supabase_id")
  embedding  Unsupported("vector(1536)")
  model      String                      @default("text-embedding-3-small")
  inputHash  String                      @map("input_hash")
  updatedAt  DateTime                    @default(now()) @map("updated_at")

  @@index([updatedAt(sort: Desc)])
  @@map("candidate_embeddings")
}

// Phase 0 Sprint 0.2 — daily eval drift snapshots. One row per task per
// scheduled run. The drift cron compares the latest mean_score to the 7-day
// moving average and alerts on >10% drops. Append-only.
model AiEvalSnapshot {
  id            String   @id @default(cuid())
  task          String
  promptVersion String   @map("prompt_version")
  meanScore     Float    @map("mean_score")
  passed        Int
  totalCases    Int      @map("total_cases")
  costUsd       Decimal  @default(0) @map("cost_usd") @db.Decimal(12, 6)
  p95LatencyMs  Int      @default(0) @map("p95_latency_ms")
  holdsBaseline Boolean  @default(false) @map("holds_baseline")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([task, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("ai_eval_snapshot")
}

// Phase 0 Sprint 0.1 — every LLM Gateway call writes one row here. Powers the
// cost / latency / error dashboards (Sprint 0.4) and eval drift cron (Sprint
// 0.2). Best-effort writes from lib/ai/cost-tracker.ts. Append-only.
model AiCallLog {
  id            String   @id @default(cuid())
  task          String // 'candidate_scoring' | 'resume_parsing' | 'embedding' | etc.
  provider      String // 'openai' | 'anthropic'
  model         String // e.g. 'gpt-5-mini'
  promptId      String?  @map("prompt_id") // populated once Sprint 0.2 prompt registry lands
  promptVersion String?  @map("prompt_version")
  tenantId      String   @map("tenant_id") // employer id, candidate user id, or 'system'
  tenantType    String   @map("tenant_type") // 'employer' | 'candidate' | 'admin' | 'system'
  inputTokens   Int      @default(0) @map("input_tokens")
  cachedTokens  Int      @default(0) @map("cached_tokens")
  outputTokens  Int      @default(0) @map("output_tokens")
  costUsd       Decimal  @default(0) @map("cost_usd") @db.Decimal(12, 6)
  latencyMs     Int      @map("latency_ms")
  cacheHit      Boolean  @default(false) @map("cache_hit")
  fallbackUsed  Boolean  @default(false) @map("fallback_used")
  error         String?
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([createdAt(sort: Desc)])
  @@index([task, createdAt(sort: Desc)])
  @@index([tenantId, createdAt(sort: Desc)])
  @@map("ai_call_log")
}

// Phase 1 Sprint 1.1.6 — sticky A/B arm assignment per tenant per experiment.
// First request inserts; subsequent reads return the same arm. Anonymous
// (signed-out) callers get a hashed-cookie tenantId so the arm survives
// across sessions for the same browser. See lib/ai/experiments.ts.
model ExperimentAssignment {
  id         String   @id @default(cuid())
  experiment String // e.g. 'semantic_search.v1'
  tenantType String   @map("tenant_type") // 'employer' | 'candidate' | 'admin' | 'system'
  tenantId   String   @map("tenant_id")
  arm        String // e.g. 'control' | 'treatment'
  assignedAt DateTime @default(now()) @map("assigned_at")

  @@unique([experiment, tenantType, tenantId], name: "experiment_assignment_unique_target")
  @@index([experiment, assignedAt(sort: Desc)])
  @@map("experiment_assignment")
}

// Per-event log used to compute arm-level CTR / apply-rate. Append-only.
model ExperimentEvent {
  id         String   @id @default(cuid())
  experiment String
  arm        String
  tenantType String   @map("tenant_type")
  tenantId   String   @map("tenant_id")
  eventType  String   @map("event_type") // 'impression' | 'click' | 'apply'
  subjectId  String?  @map("subject_id") // e.g. job id for an apply event
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([experiment, arm, eventType, createdAt(sort: Desc)])
  @@index([tenantType, tenantId, createdAt(sort: Desc)])
  @@map("experiment_event")
}

/// First-party attribution log for social-campaign short links (`/r/<code>`).
/// One row per request after the route handler clears bot filtering, IP
/// hashing, and rate limiting. Append-only — never updated, retention sweep
/// runs via a cron job on `created_at`.
///
/// Privacy model:
///   - `ip_hash`: sha256 of (client IP || daily-rotated salt). Same user on
///     same day deduplicates; cross-day correlation is computationally hard.
///   - `user_agent` / `referer`: truncated to 512 chars to bound row size
///     and reduce fingerprint surface.
///   - Honors DNT/GPC: those requests still resolve to a redirect but the
///     row is dropped pre-insert (see lib/shortlinks/tracker.ts).
///
/// Bots: insert with `is_bot=true` and a `bot_name` label so analysts can
/// see preview-card fetches separately. Real-click totals filter `is_bot=false`.
model ShortLinkClick {
  id              String   @id @default(cuid())
  /// Short code as received from `/r/<code>` (lowercased before insert).
  code            String
  /// Campaign slug — keyed off `lib/shortlinks/campaigns.ts`. Frozen at
  /// insert so renaming a campaign later doesn't rewrite history.
  campaign        String
  /// Resolved platform name (facebook, instagram, linkedin, x, reddit, threads).
  platform        String
  /// Per-job content slug (e.g. `resiliency-anaheim`). Frozen at insert.
  content         String
  /// Numeric id within the campaign config (0 = browse-all landing).
  jobId           Int      @map("job_id")
  /// Destination path the user was sent to (e.g. `/jobs/<slug>`). Stored
  /// for forensics if a destination ever 404s after a campaign ships.
  destinationPath String   @map("destination_path")
  /// sha256 of (ip || daily salt). Null when no IP is available.
  ipHash          String?  @map("ip_hash")
  /// Truncated UA string. Null when absent.
  userAgent       String?  @map("user_agent")
  /// Truncated Referer. Null when absent or stripped by browser.
  referer         String?
  /// Two-letter country from Vercel/CloudFront edge headers.
  country         String?  @db.VarChar(2)
  /// True if a known link-preview / search crawler UA was detected.
  isBot           Boolean  @default(false) @map("is_bot")
  /// Short label for the matched bot family (e.g. `facebookexternalhit`).
  botName         String?  @map("bot_name")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([campaign, platform, createdAt])
  @@index([campaign, isBot, createdAt])
  // Supports the COUNT(DISTINCT ip_hash) WHERE campaign=? AND created_at
  // BETWEEN ? AND ? query in the admin stats endpoint. Without this the
  // distinct-IP roll-up filtered-table-scans on every dashboard load.
  @@index([campaign, createdAt, ipHash])
  @@index([code, createdAt])
  @@index([createdAt])
  @@map("shortlink_clicks")
}
