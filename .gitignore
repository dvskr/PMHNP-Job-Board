# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# playwright artifacts (reports, traces, screenshots, videos)
/playwright-report
/test-results
/tests/e2e/.results
.playwright

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!.env.test.example

# Local audit-script artifacts — contain prod data snapshots, not for commit
.tmp_*

# Local email preview / test renders (generated by scripts/render-test-email.js)
_email_preview_*.html
test-*-email.html
test-alert-email.html
test-candidate-welcome.html
test-employer-welcome.html

# Local debugging artifacts under scripts/ — one-off diagnostic scripts
# (named after specific users/incidents) and screenshots from manual debug
# sessions. None of these should ever be committed.
scripts/diag-*.ts
scripts/debug-*.mjs
scripts/inspect-*.mjs
scripts/*.png

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/app/generated/prisma

# data exports and sensitive files
*.csv
/data/
/tmp/
/scripts/export-*.js

# Archive of old files
/_archive/

# Screenshots & recordings (marketing assets, not code)
/screenshots/
/recordings/

# One-off root scripts & output
output.html
post-social-now.js
preview-social-post.*
check-jobs.js
convert-images.mjs
copy-videos.mjs
take-screenshots.mjs
take-videos.mjs
*.log
*.pdf
tmp-all-domains.txt

# Script output files (generated reports/data)
/scripts/*.txt
/scripts/alert-report.md
/scripts/sample-resume.html
/scripts/alert-users.json
/scripts/ats-companies.json
/scripts/ats-test-results.json
/scripts/fix-blog-content-body.json

# SQL one-offs
/sql/
supabase_dashboard_queries.sql

# YouTube automation assets (large files, generated content)
/yt-videos/
/yt-thumbnails/
/scripts/schedule-log.json

# Google Search Console exports — both raw drilldowns and the parent folder
# the user occasionally drops the unzipped archive into ("GSC ISSUES/").
https___pmhnphiring.com_-*/
/GSC*ISSUES/
/gsc-removal-*
/gsc-stale-*

# NotebookLM prompts (local only)
notebooklm-*.md

# Vercel log exports (multi-MB JSON / CSV dumps)
/pmhnp-job-board-log-export-*

# GitHub Actions log archives unzipped at root
/logs_*/

# One-off design mockups occasionally dropped at root
/*.html
!/*.example.html

# Stray "tmp_*" scripts a previous session left at root
/tmp_*

/videos/
/videos_backup/
/thumbnails/

# Recovery artifacts (not production code)
/_recovery/

# Claude Code harness state (per-session locks, etc.)
.claude/
