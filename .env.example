# =============================================================================
# Environment variables — example file
# =============================================================================
#
# Copy to `.env` (or `.env.local`) and replace every <placeholder> with a
# real value. Production values live in Vercel → Settings → Environment Variables.
#
# CORE vars are validated on startup by lib/env.ts (Zod schema): required ones
# throw at boot in production, optional ones have built-in defaults. The
# integration keys further down are read directly where they're used (not all
# are in the Zod schema), so a missing one degrades that one feature silently
# rather than failing boot.
#
# =============================================================================
# CORE — required
# =============================================================================

# Postgres connection string (Supabase / local Postgres / etc.)
DATABASE_URL=<postgres-connection-string>

# Supabase project — required for auth + storage
NEXT_PUBLIC_SUPABASE_URL=<https://your-project.supabase.co>
NEXT_PUBLIC_SUPABASE_ANON_KEY=<supabase-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<supabase-service-role-key>

# Public site URL — used in email links, OG tags, sitemap
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Cron auth — protects every /api/cron/* endpoint. Min 16 chars.
# Generate with: openssl rand -hex 32
CRON_SECRET=<random-32-char-hex-string>

# Node mode — 'development' | 'production' | 'test'
NODE_ENV=development

# =============================================================================
# EMAIL — required for any sender to actually deliver
# =============================================================================

# Resend API key — without this, every send fails silently.
# Get from https://resend.com/api-keys
RESEND_API_KEY=<your-resend-api-key>

# Resend webhook signing secret — required so /api/webhooks/resend can verify
# Svix signatures. Without this the webhook returns 500 and bounce/complaint
# events never flip suppression flags. Set in Resend dashboard → Webhooks.
RESEND_WEBHOOK_SECRET=<your-resend-webhook-secret>

# Transactional sender (default if EMAIL_FROM_MARKETING is unset).
# MUST use the "Display Name <email@domain>" format — bare email gets sent
# as-is and looks unprofessional in inboxes.
EMAIL_FROM=PMHNP Hiring <noreply@pmhnphiring.com>

# Marketing sender — used for job alerts, candidate alerts, performance
# reports, saved-job reminders, broadcasts, salary guide, welcome.
# (Defined in MARKETING_EMAIL_TYPES in lib/email-service.ts.)
# Splitting transactional vs marketing onto two From: addresses gives Gmail/
# Yahoo a per-stream reputation signal — a complaint on alerts doesn't tank
# transactional deliverability.
EMAIL_FROM_MARKETING=PMHNP Hiring <alerts@pmhnphiring.com>

# PD outreach sender — personal from-name for the cold Program Director
# partnership campaign. Routed via emailType='pd_outreach' in
# sendAndLog. Falls back to EMAIL_FROM_MARKETING if unset. Keep this
# distinct from EMAIL_FROM_MARKETING so personal-feeling cold outreach
# doesn't bleed into automated job alerts.
EMAIL_FROM_PD_OUTREACH=Sathish from PMHNP Hiring <hello@pmhnphiring.com>

# Reply-to on every send. Where users reply when they hit "Reply" in their
# inbox. Should be a monitored mailbox.
EMAIL_REPLY_TO=support@pmhnphiring.com

# Postmark DMARC monitoring (OPTIONAL) — API token from
# https://dmarc.postmarkapp.com. Only needed to pull DMARC report data
# programmatically (e.g., for a custom dashboard). Reports themselves
# arrive at Postmark via the `rua=mailto:re+xxxx@dmarc.postmarkapp.com`
# entry in the domain's `_dmarc` TXT record — no env var required for
# the reports themselves, only for API access.
POSTMARK_DMARC_API_TOKEN=<your-postmark-dmarc-token>

# CDN base URL for email images (logo, hero, step icons). Defaults to the
# Supabase email-assets public bucket. Override if you re-host.
EMAIL_ASSETS_URL=<https://your-project.supabase.co/storage/v1/object/public/email-assets>

# Public PDF URL for the salary-guide download email. Hardcoded fallback
# in lib/env.ts; set explicitly so you can swap PDFs without a redeploy.
SALARY_GUIDE_URL=<https://your-project.supabase.co/storage/v1/object/public/resources/Salary_Guide.pdf>

# =============================================================================
# STRIPE — optional; only needed if ENABLE_PAID_POSTING=true
# =============================================================================

STRIPE_SECRET_KEY=<stripe-secret-key>
STRIPE_WEBHOOK_SECRET=<stripe-webhook-secret>
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=<stripe-publishable-key>
ENABLE_PAID_POSTING=false

# =============================================================================
# JOB AGGREGATORS — all optional; missing keys just disable that source
# =============================================================================

ADZUNA_APP_ID=
ADZUNA_APP_KEY=
JOOBLE_API_KEY=
# USAJobs: register at https://developer.usa.gov/ to get an API key; the
# User-Agent must be the email you registered with (their TOS requires it).
USAJOBS_API_KEY=
USAJOBS_USER_AGENT=

# =============================================================================
# SEARCH ENGINE INDEXING — optional but strongly recommended
# =============================================================================
# Powers the cron pipeline at lib/search-indexing.ts (index-urls,
# index-pseo, deindex-expired). Without these set, the indexing crons
# return 200 OK with zero actual submissions and no Discord alert —
# look indistinguishable from success.

# IndexNow (Bing + Yandex unlimited submissions, fastest discovery for new jobs).
# Generate any 8-128 char hex string; serve it from /<key>.txt at the root.
# See app/[indexnow]/route.ts for the verification endpoint.
# (INDEXNOW_KEY further down is accepted as a legacy alias — this one wins.)
INDEXNOW_API_KEY=

# Bing Webmaster Tools API key (per-site URL submissions, 10K/day default).
# Bing Webmaster → Settings → API Access.
BING_WEBMASTER_API_KEY=

# Bing Webmaster site verification meta tag value. Without this the IndexNow
# pipeline runs blind — no Bing dashboard visibility into submissions,
# coverage, or errors. Bing Webmaster → Settings → Site verification →
# HTML meta tag method.
BING_WEBMASTER_VERIFICATION=

# Google Indexing API service account credentials (JSON, 200/day quota).
# Used by lib/search-indexing.ts for net-new and URL_DELETED submissions.
# Stringify the service-account JSON object before assigning.
GOOGLE_INDEXING_CREDENTIALS=

# =============================================================================
# MONITORING — optional
# =============================================================================

# Server/edge error monitoring DSN (used by sentry.server/edge.config.ts).
SENTRY_DSN=
# Client error monitoring DSN — exposed to the browser, so it must be public.
# Usually the same value as SENTRY_DSN. Read by instrumentation-client.ts.
NEXT_PUBLIC_SENTRY_DSN=
LOG_LEVEL=info  # debug | info | warn | error

# Sentry source-map upload (build-time only, optional).
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# =============================================================================
# DATABASE — direct / prod-mirror connections
# =============================================================================

# Direct (non-pooled) Postgres URL. REQUIRED by the Prisma CLI for
# `prisma migrate deploy` (prisma.config.ts / schema datasource directUrl).
# Without it, dev/build migration steps fail.
DIRECT_URL=<postgres-direct-connection-string>

# Prod-mirror connections — used by middleware's edge 410-lookup fallback and
# by ops scripts that target production from a local shell.
PROD_DATABASE_URL=
PROD_DIRECT_URL=
PROD_DIRECT_DATABASE_URL=
PROD_SUPABASE_URL=
PROD_SUPABASE_SERVICE_ROLE_KEY=

# =============================================================================
# AI / LLM — required for semantic search, enrichment, recommendations
# =============================================================================

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Optional Claude proxy (overrides direct Anthropic access when set).
CLAUDE_PROXY_API_KEY=
CLAUDE_PROXY_BASE_URL=
CLAUDE_PROXY_MODEL=
# AI feature kill switches (set to 'true' to disable that feature).
KILL_AI_CANDIDATE_COVER_LETTER=
KILL_AI_CANDIDATE_RESUME_PARSER=

# =============================================================================
# RATE LIMITING (Upstash Redis) — optional; falls back to in-memory if unset
# =============================================================================
# Without Redis, rate limiting is per-instance only (resets on cold start).

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# =============================================================================
# JOB INGEST — additional sources
# =============================================================================

# RapidAPI key for the fantastic-jobs-db / ats-jobs-db scheduled crons.
RAPIDAPI_KEY=

# =============================================================================
# PUSH NOTIFICATIONS (Web Push / VAPID) — optional
# =============================================================================
# Generate with: npx web-push generate-vapid-keys

NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# =============================================================================
# SEARCH CONSOLE / INDEXNOW — additional
# =============================================================================

# Google Search Console service-account JSON (stringified) + verified site URL.
# Powers the gsc-health-check / historical-deindex crons.
GSC_SERVICE_ACCOUNT_KEY=
GSC_SITE_URL=

# NOTE: every IndexNow reader (lib/indexnow.ts, lib/search-indexing.ts,
# app/[indexnow]/route.ts, scripts/gsc-resubmit.ts) accepts either
# INDEXNOW_API_KEY (preferred, above) or INDEXNOW_KEY as a legacy alias.
# Setting one is enough; INDEXNOW_API_KEY wins when both are set.
INDEXNOW_KEY=

# =============================================================================
# BACKGROUND JOBS (Inngest) — optional
# =============================================================================

INNGEST_EVENT_KEY=

# =============================================================================
# INTEGRATIONS — notifications, extension, newsletter, blog, social, analytics
# =============================================================================

# Discord webhook for cron-failure + anomaly alerts.
DISCORD_WEBHOOK_URL=

# Signing secret for the browser autofill extension's JWTs.
EXTENSION_JWT_SECRET=

# Server-side hashing salts/secrets (set to stable random values; rotating
# them invalidates existing hashed IPs / short-link signatures).
EMAIL_HASH_SALT=
SHORTLINK_HASH_SECRET=
NEXTAUTH_SECRET=

# Cloudmersive virus scanning for uploads (optional).
CLOUDMERSIVE_API_KEY=
# 'true' = let uploads through when the scanner is unreachable (fail-open).
VIRUS_SCAN_FAIL_OPEN=

# Beehiiv newsletter sync.
BEEHIIV_API_KEY=
BEEHIIV_API=
BEEHIIV_PUBLICATION_ID=

# Blog content API.
BLOG_API_KEY=
BLOG_API_BASE_URL=

# Postiz social-posting (the social-post / instagram-post crons are PAUSED, so
# these are only needed if those are re-enabled).
POSTIZ_API_KEY=
POSTIZ_API_URL=
POSTIZ_FB_INTEGRATION_ID=
POSTIZ_INSTAGRAM_INTEGRATION_ID=
POSTIZ_LI_INTEGRATION_ID=
POSTIZ_X_INTEGRATION_ID=
POSTIZ_YT_INTEGRATION_ID=

# YouTube Data API (video sitemap / channel content).
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=

# Google Analytics 4 Measurement Protocol (server-side events) + client tag.
GA_MEASUREMENT_ID=
GA_API_SECRET=
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Public URL overrides (default to NEXT_PUBLIC_BASE_URL where applicable).
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_BACKEND_URL=
NEXT_PUBLIC_BOXLITE_API_URL=

# Storage path overrides.
STORAGE_UPLOAD_PREFIX=
SUPABASE_STATE_IMAGE_BASE=

# Base URL for public site assets (images/icons/PDFs) — OPTIONAL override,
# read by lib/asset-url.ts. Defaults to the current asset project's public
# storage root (https://sggccmqjzuimwlahocmy.supabase.co/storage/v1/object/public).
# NOTE: the asset host is a DIFFERENT Supabase project from the app database/
# auth project (NEXT_PUBLIC_SUPABASE_URL) — set this only if assets move.
# No trailing slash.
NEXT_PUBLIC_ASSET_BASE_URL=

# =============================================================================
# JOB-HEALTH ANOMALY TUNING — optional, all have sane defaults in code
# =============================================================================

JOB_HEALTH_ANOMALY_DEAD_SIGMA=
JOB_HEALTH_ANOMALY_FLIP_MULT=
JOB_HEALTH_ANOMALY_SKIP_PCT=
JOB_HEALTH_ANOMALY_SOFT_MULT=
JOB_HEALTH_MIN_PRESENCE_MISSES=

# =============================================================================
# TESTING / CI ONLY — not needed to run the app
# =============================================================================
# Used by Playwright e2e specs and scripts/audit/* tooling. Real test-account
# credentials must NOT be committed — set these in your shell or CI secrets.

E2E_DATABASE_URL=
E2E_SUPABASE_URL=
E2E_SUPABASE_SERVICE_ROLE_KEY=
E2E_ADMIN_EMAIL=
E2E_ADMIN_PASS=
E2E_EMPLOYER_EMAIL=
E2E_EMPLOYER_PASS=
E2E_SEEKER_EMAIL=
E2E_SEEKER_PASS=
E2E_TEST_JOB_ID=
E2E_TEST_RESUME_PATH=
PLAYWRIGHT_BASE_URL=
AUDIT_BASE_URL=
AUDIT_DB_URL=
AUDIT_ENV_FILE=
AUDIT_USE_PROD=
AUDIT_EMPLOYER_EMAIL=
AUDIT_EMPLOYER_PASS=
AUDIT_SEEKER_EMAIL=
AUDIT_SEEKER_PASS=
