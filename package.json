{
  "name": "pmhnp-job-board",
  "version": "0.1.0",
  "private": true,
  "prisma": {
    "schema": "prisma/schema.prisma",
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "scripts": {
    "dev": "prisma migrate deploy && next dev",
    "dev:nomigrate": "next dev",
    "prebuild": "node -e \"process.env.TEMP=process.env.USERPROFILE+'\\\\AppData\\\\Local\\\\Temp';process.env.TMP=process.env.TEMP\"",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "rimraf .next out dist",
    "validate": "npm run type-check && npm run lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test smoke",
    "test:e2e:regression": "playwright test regression",
    "test:e2e:seo": "playwright test seo",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install chromium",
    "postinstall": "prisma generate",
    "audit:jobs": "ts-node --project scripts/tsconfig.json scripts/audit-and-fix-jobs.ts",
    "audit:salaries": "ts-node --project scripts/tsconfig.json scripts/audit-salaries.ts",
    "fix:locations": "ts-node --project scripts/tsconfig.json scripts/fix-missing-locations.ts",
    "fix:salaries": "ts-node --project scripts/tsconfig.json scripts/fix-all-salaries.ts",
    "populate:display-salaries": "ts-node --project scripts/tsconfig.json scripts/populate-display-salaries.ts",
    "clean:descriptions": "ts-node --project scripts/tsconfig.json scripts/clean-job-descriptions.ts",
    "ingest": "ts-node -r tsconfig-paths/register --project scripts/tsconfig.json scripts/run-ingestion.ts",
    "eval": "ts-node -r tsconfig-paths/register --project scripts/tsconfig.json scripts/run-eval.ts",
    "prompt:diff": "ts-node -r tsconfig-paths/register --project scripts/tsconfig.json scripts/prompt-diff.ts",
    "backfill:embeddings": "ts-node -r tsconfig-paths/register --project scripts/tsconfig.json scripts/backfill-embeddings.ts",
    "lint:pii-prompts": "ts-node -r tsconfig-paths/register --project scripts/tsconfig.json scripts/scan-prompt-pii.ts",
    "db:sync-from-prod": "ts-node -r tsconfig-paths/register --project scripts/tsconfig.json scripts/sync-prod-jobs-to-local.ts",
    "db:check-schema": "ts-node -r tsconfig-paths/register --project scripts/tsconfig.json scripts/check-schema.ts --env=prod",
    "db:check-schema:prod": "ts-node -r tsconfig-paths/register --project scripts/tsconfig.json scripts/check-schema.ts --env=prod",
    "db:check-schema:dev": "ts-node -r tsconfig-paths/register --project scripts/tsconfig.json scripts/check-schema.ts --env=dev",
    "db:migrate:prod": "ts-node -r tsconfig-paths/register --project scripts/tsconfig.json scripts/migrate-prod.ts",
    "recs:run": "ts-node -r tsconfig-paths/register --project scripts/tsconfig.json scripts/run-recommendations.ts",
    "seed:test-candidates": "ts-node -r tsconfig-paths/register --project scripts/tsconfig.json scripts/seed-test-candidates.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@paralleldrive/cuid2": "^3.0.4",
    "@phosphor-icons/react": "^2.1.10",
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^7.4.1",
    "@react-pdf/renderer": "^4.3.1",
    "@resvg/resvg-js": "^2.6.2",
    "@sentry/nextjs": "^10.50.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.88.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/web-push": "^3.6.4",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.2",
    "@vercel/og": "^0.8.6",
    "@vercel/speed-insights": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "framer-motion": "^12.34.0",
    "google-auth-library": "^10.6.2",
    "gray-matter": "^4.0.3",
    "inngest": "^4.2.5",
    "jose": "^6.1.3",
    "lucide-react": "^0.555.0",
    "mammoth": "^1.12.0",
    "next": "^16.0.10",
    "next-mdx-remote": "^6.0.0",
    "openai": "^6.32.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.16.3",
    "playwright": "^1.58.2",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.67.0",
    "react-quill-new": "^3.8.3",
    "resend": "^6.5.2",
    "sanitize-html": "^2.17.0",
    "satori": "^0.19.2",
    "stripe": "^20.0.0",
    "tailwind-merge": "^3.4.0",
    "web-push": "^3.6.7",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.1.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.15.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sanitize-html": "^2.16.0",
    "@types/sharp": "^0.31.1",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9",
    "eslint-config-next": "16.0.7",
    "prisma": "^7.4.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5",
    "vitest": "^2.1.8"
  }
}
