# =============================================================================
# Credentials for E2E tests (Playwright)
# =============================================================================
# Copy to `.env.test` (gitignored) and fill in real values.
# Tests that require any credential auto-skip if its env var is empty.
#
#   cp .env.test.example .env.test
#
# All tests run against http://localhost:3000 by default. Override:
#   PLAYWRIGHT_BASE_URL=https://my-preview.vercel.app
# =============================================================================

# ── Job seeker test account ──────────────────────────────────────────────────
# Used by tests/e2e/journeys/job-seeker.spec.ts. Create via:
#   npx ts-node create-test-users.ts
E2E_SEEKER_EMAIL=testseeker@pmhnptest.com
E2E_SEEKER_PASS=TestSeeker123!

# ── Employer test account ────────────────────────────────────────────────────
# Used by tests/e2e/journeys/employer.spec.ts.
E2E_EMPLOYER_EMAIL=testemployer@pmhnptest.com
E2E_EMPLOYER_PASS=TestEmployer123!

# ── Admin test account ───────────────────────────────────────────────────────
# Must have role=admin in your Supabase user table.
E2E_ADMIN_EMAIL=
E2E_ADMIN_PASS=

# ── Stripe test card (for employer post-job checkout flow) ───────────────────
# Stripe test card numbers: https://stripe.com/docs/testing#cards
# Default: a card that succeeds.
E2E_STRIPE_TEST_CARD=4242424242424242
E2E_STRIPE_TEST_EXP=12/34
E2E_STRIPE_TEST_CVC=123
E2E_STRIPE_TEST_ZIP=10001

# ── Test job ID (for apply / save / message flows) ───────────────────────────
# Optional. If unset, tests pick the first published job from the listings page.
E2E_TEST_JOB_ID=

# ── Test resume file path (for resume upload + AI parse flow) ────────────────
# Path relative to repo root. Defaults to tests/e2e/fixtures/sample-resume.pdf.
E2E_TEST_RESUME_PATH=tests/e2e/fixtures/sample-resume.pdf
